# News RAG System local environment template


# External source credentials
NEWS_API_KEY=your_news_api_key_here
# EXAMPLE_API_KEY=your_example_api_key_here

# Required when EMBEDDING_PROVIDER=openai or SENTIMENT_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# Local fallback mode: deterministic hash vectors.
# If you switch to this mode, recreate the OpenSearch index with 16 dimensions:
# .\scripts\opensearch\create-news-article-index.ps1 -Recreate -EmbeddingDimension 16
# EMBEDDING_PROVIDER=simple-hash
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=16

SENTIMENT_PROVIDER=openai
SENTIMENT_MODEL=gpt-4.1-mini
SENTIMENT_MAX_TEXT_CHARS=3000

# Fully local fallback mode:
# SENTIMENT_PROVIDER=simple
# SENTIMENT_MODEL=
# SENTIMENT_MAX_TEXT_CHARS=3000

 INGESTION_HTTP_MAX_RETRIES=3
INGESTION_HTTP_RETRY_DELAY_MS=500